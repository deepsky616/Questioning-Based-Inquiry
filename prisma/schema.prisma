generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  STUDENT
  TEACHER
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique @map("email")
  password  String   @map("password")
  name      String   @map("name")
  role      UserRole @map("role")

  grade         String?  @map("grade")
  className     String?  @map("class_name")
  studentNumber String?  @map("student_number")

  school    String?  @map("school")

  questions Question[] @relation("QuestionAuthor")
  comments  Comment[] @relation("CommentAuthor")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("users")
}

model Question {
  id             String  @id @default(cuid())
  content        String  @map("content")
  closure        String  @map("closure")
  cognitive      String  @map("cognitive")
  closureScore   Float?  @map("closure_score")
  cognitiveScore Float?  @map("cognitive_score")
  context        String? @map("context")

  authorId String @map("author_id")
  author   User   @relation("QuestionAuthor", fields: [authorId], references: [id])
  comments Comment[] @relation("QuestionComments")

  isPublic  Boolean @default(false) @map("is_public")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("questions")
}

model Comment {
  id         String   @id @default(cuid())
  content    String   @map("content")
  authorId   String   @map("author_id")
  author     User     @relation("CommentAuthor", fields: [authorId], references: [id])
  questionId String   @map("question_id")
  question   Question @relation("QuestionComments", fields: [questionId], references: [id])
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("comments")
}

model SystemConfig {
  id        String   @id @default(cuid())
  key       String   @unique @map("config_key")
  value     String   @map("config_value")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("system_configs")
}