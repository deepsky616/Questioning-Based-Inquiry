generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  STUDENT
  TEACHER
}

model User {
  id       String   @id @default(cuid())
  email    String   @unique @map("email")
  password String   @map("password")
  name     String   @map("name")
  role     UserRole @map("role")

  grade         String? @map("grade")
  className     String? @map("class_name")
  studentNumber String? @map("student_number")

  school String? @map("school")

  questions           Question[]           @relation("QuestionAuthor")
  comments            Comment[]            @relation("CommentAuthor")
  sessions            QuestionSession[]    @relation("SessionTeacher")
  teacherClasses      TeacherClass[]       @relation("TeacherClasses")
  passwordResetTokens PasswordResetToken[] @relation("PasswordResetTokens")
  unitDesigns         UnitDesign[]         @relation("UnitDesigns")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("users")
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  tokenHash String    @unique @map("token_hash")
  userId    String    @map("user_id")
  user      User      @relation("PasswordResetTokens", fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  @@index([userId])
  @@map("password_reset_tokens")
}

model TeacherClass {
  id        String @id @default(cuid())
  teacherId String @map("teacher_id")
  teacher   User   @relation("TeacherClasses", fields: [teacherId], references: [id], onDelete: Cascade)
  grade     String @map("grade")
  className String @map("class_name")

  @@unique([teacherId, grade, className])
  @@map("teacher_classes")
}

model QuestionSession {
  id              String     @id @default(cuid())
  date            String     @map("session_date")
  subject         String     @map("subject")
  topic           String     @default("") @map("topic")
  teacherId       String     @map("teacher_id")
  teacher         User       @relation("SessionTeacher", fields: [teacherId], references: [id])
  questions       Question[] @relation("SessionQuestions")
  unitDesignId    String?    @map("unit_design_id")
  sharedQuestions Json       @default("[]") @map("shared_questions")
  defaultQuestionPublic Boolean @default(false) @map("default_question_public")
  createdAt       DateTime   @default(now()) @map("created_at")

  @@map("question_sessions")
}

model Question {
  id             String  @id @default(cuid())
  content        String  @map("content")
  closure        String  @map("closure")
  cognitive      String  @map("cognitive")
  closureScore   Float?  @map("closure_score")
  cognitiveScore Float?  @map("cognitive_score")
  context        String? @map("context")

  sessionId String?          @map("session_id")
  session   QuestionSession? @relation("SessionQuestions", fields: [sessionId], references: [id])

  authorId String    @map("author_id")
  author   User      @relation("QuestionAuthor", fields: [authorId], references: [id])
  comments Comment[] @relation("QuestionComments")

  isPublic  Boolean  @default(false) @map("is_public")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("questions")
}

model Comment {
  id         String   @id @default(cuid())
  content    String   @map("content")
  authorId   String   @map("author_id")
  author     User     @relation("CommentAuthor", fields: [authorId], references: [id])
  questionId String   @map("question_id")
  question   Question @relation("QuestionComments", fields: [questionId], references: [id])
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("comments")
}

model SystemConfig {
  id        String   @id @default(cuid())
  key       String   @unique @map("config_key")
  value     String   @map("config_value")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("system_configs")
}

// 2022 개정 교육과정 시드 데이터
model CurriculumArea {
  id             String   @id @default(cuid())
  subject        String   @map("subject")        // "과학", "사회", "국어" …
  gradeRange     String   @map("grade_range")    // "1-2", "3-4", "5-6"
  area           String   @map("area")           // 영역명 ("생명", "물질" …)
  coreIdea       String   @db.Text @map("core_idea")
  knowledgeItems       Json  @map("knowledge_items")        // 지식·이해 내용요소 (해당 학년군)
  processItems         Json  @map("process_items")          // 과정·기능 내용요소 (해당 학년군)
  valueItems           Json  @map("value_items")            // 가치·태도 내용요소 (해당 학년군)
  middleKnowledgeItems Json? @map("middle_knowledge_items") // 중학교 지식·이해 (선행 확인용)
  middleProcessItems   Json? @map("middle_process_items")   // 중학교 과정·기능 (선행 확인용)
  middleValueItems     Json? @map("middle_value_items")     // 중학교 가치·태도 (선행 확인용)
  achievements         Json  @map("achievements")           // [{code, content}] 성취기준
  units                Json  @default("[]") @map("units")  // [{unitCode, unitName}] 영역 내 단원 목록

  unitDesigns    UnitDesign[]

  @@index([subject, gradeRange])
  @@map("curriculum_areas")
}

// 교사가 생성·저장한 단원 설계
model UnitDesign {
  id                 String          @id @default(cuid())
  teacherId          String          @map("teacher_id")
  teacher            User            @relation("UnitDesigns", fields: [teacherId], references: [id], onDelete: Cascade)
  curriculumAreaId   String?         @map("curriculum_area_id")
  curriculumArea     CurriculumArea? @relation(fields: [curriculumAreaId], references: [id])

  title              String          @map("title")
  subject            String          @map("subject")
  gradeRange         String          @map("grade_range")
  area               String          @map("area")
  coreIdea           String          @db.Text @map("core_idea")
  selectedKeywords   Json            @map("selected_keywords")   // string[]
  coreSentences      Json            @map("core_sentences")      // string[]
  essentialQuestions Json            @map("essential_questions") // string[]
  inquiryQuestions   Json            @map("inquiry_questions")   // [{type, content}][]

  createdAt          DateTime        @default(now()) @map("created_at")
  updatedAt          DateTime        @updatedAt @map("updated_at")

  @@map("unit_designs")
}
